#!/bin/bash
# Helper script to run GitHub workflows locally

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ACT="${SCRIPT_DIR}/bin/act"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

cd "$REPO_ROOT"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Show help
show_help() {
    cat << EOF
${BLUE}Local GitHub Actions Runner${NC}

Usage: $0 [COMMAND] [OPTIONS]

COMMANDS:
  list              List all available workflows and jobs
  lint              Run code linting checks
  test              Run full test suite with MySQL
  build             Build Docker images
  test-all          Run: lint → test → build (full CI)
  deploy-local      Deploy to local Kind cluster
  deploy-aws        Deploy to AWS EKS (requires credentials)
  
OPTIONS:
  -v, --verbose     Show detailed output
  -h, --help        Show this help message

EXAMPLES:
  $0 lint                 # Run linting
  $0 test --verbose       # Run tests with verbose output
  $0 test-all             # Run complete CI pipeline
  
For more info, see: docs/LOCAL_WORKFLOWS.md
EOF
}

# Check if act is installed
if [ ! -f "$ACT" ]; then
    echo -e "${RED}✗ act not found at $ACT${NC}"
    echo "Install with: curl https://raw.githubusercontent.com/nektos/act/master/install.sh | bash"
    exit 1
fi

# Check if Docker is running
if ! docker ps > /dev/null 2>&1; then
    echo -e "${RED}✗ Docker is not running${NC}"
    echo "Start Docker and try again"
    exit 1
fi

# Parse arguments
COMMAND="${1:-list}"
VERBOSE=""

if [[ "$@" == *"--verbose"* ]] || [[ "$@" == *"-v"* ]]; then
    VERBOSE="-v"
fi

case "$COMMAND" in
    list)
        echo -e "${BLUE}Available workflows and jobs:${NC}"
        $ACT -l
        ;;
    lint)
        echo -e "${BLUE}Running: Lint check${NC}"
        $ACT -j lint $VERBOSE
        echo -e "${GREEN}✓ Lint passed${NC}"
        ;;
    test)
        echo -e "${BLUE}Running: Tests (with MySQL)${NC}"
        $ACT -j test $VERBOSE
        echo -e "${GREEN}✓ Tests passed${NC}"
        ;;
    build)
        echo -e "${BLUE}Running: Docker build${NC}"
        $ACT -j build-and-push $VERBOSE
        echo -e "${GREEN}✓ Docker build completed${NC}"
        ;;
    test-all)
        echo -e "${BLUE}Running complete CI pipeline${NC}"
        echo -e "${YELLOW}Step 1/3: Lint${NC}"
        $ACT -j lint
        echo -e "${GREEN}✓ Lint passed${NC}\n"
        
        echo -e "${YELLOW}Step 2/3: Test${NC}"
        $ACT -j test
        echo -e "${GREEN}✓ Tests passed${NC}\n"
        
        echo -e "${YELLOW}Step 3/3: Build${NC}"
        $ACT -j build-and-push
        echo -e "${GREEN}✓ Docker build completed${NC}\n"
        
        echo -e "${GREEN}✓ All CI checks passed!${NC}"
        ;;
    deploy-local)
        echo -e "${BLUE}Running: Deploy to Kind cluster${NC}"
        $ACT workflow_dispatch -W .github/workflows/deploy-local.yml $VERBOSE
        echo -e "${GREEN}✓ Deployment to Kind completed${NC}"
        ;;
    deploy-aws)
        echo -e "${BLUE}Running: Deploy to AWS EKS${NC}"
        echo -e "${YELLOW}Note: Requires AWS credentials configured${NC}"
        $ACT workflow_dispatch -W .github/workflows/deploy-aws.yml $VERBOSE
        echo -e "${GREEN}✓ AWS deployment completed${NC}"
        ;;
    -h|--help|help)
        show_help
        ;;
    *)
        echo -e "${RED}✗ Unknown command: $COMMAND${NC}"
        echo ""
        show_help
        exit 1
        ;;
esac
