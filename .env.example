# Video Streaming Platform - Environment Configuration
# Copy this to .env and update values for your environment

# Application Environment
ENVIRONMENT=dev
DEBUG_MODE=false
LOG_LEVEL=info

# Data Service Configuration
HTTP_PORT=8081
GRPC_PORT=50051
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=120s
GRACEFUL_SHUTDOWN_TIMEOUT=30s

# Metadata Service Configuration
METADATA_HTTP_PORT=8080

# Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=videouser
MYSQL_PASSWORD=videopass
MYSQL_DATABASE=videoplatform
MYSQL_MAX_CONN=25

# S3 Configuration
S3_REGION=us-east-1
S3_BUCKET=video-platform-storage
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# OpenTelemetry Configuration
OTEL_ENABLED=false
OTEL_TRACES_ENABLED=false
OTEL_METRICS_ENABLED=false
OTEL_JAEGER_URL=http://localhost:14268/api/traces

# Kafka Configuration (for future use)
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_WATCH_HISTORY=watch-history

# Feature Flags
FEATURE_RECOMMENDATION_ENGINE=false
FEATURE_SEARCH_SERVICE=false
